// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearch"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis(version: "3.4"), uuidOssp(map: "uuid-ossp"), pgTrgm(map: "pg_trgm")]
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  CITIZEN
  INSTITUTION_OFFICER
  SUPER_ADMIN
}

enum Category {
  WATER_SANITATION // Su ve Kanalizasyon
  TRANSPORTATION // Yol / Ulaşım
  ENVIRONMENT // Çevre ve Temizlik
  INFRASTRUCTURE // Altyapı
  SECURITY // Güvenlik
  LIGHTING // Aydınlatma
  PARKS // Park ve Yeşil Alan
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IssueStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  REJECTED
}

// ─── MODELS ───────────────────────────────────────────────────────────────────

model User {
  id           String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email        String  @unique @db.VarChar(255)
  passwordHash String  @map("password_hash") @db.VarChar(255)
  role         Role    @default(CITIZEN)
  isVerified   Boolean @default(false) @map("is_verified")

  // NVİ doğrulanmış veriler — sadece doğrulama sonrası dolu
  tcKimlikHash String? @map("tc_kimlik_hash") @db.VarChar(64) // SHA-256, plaintext saklanmaz
  firstName    String? @map("first_name") @db.VarChar(100)
  lastName     String? @map("last_name") @db.VarChar(100)
  birthYear    Int?    @map("birth_year")

  // Kurum bilgisi (sadece INSTITUTION_OFFICER için dolu)
  institutionId String?      @map("institution_id") @db.Uuid
  institution   Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)

  // 2FA bilgileri
  twoFactorSecret    String? @map("two_factor_secret") @db.VarChar(100)
  isTwoFactorEnabled Boolean @default(false) @map("is_two_factor_enabled")

  // Profil
  phone     String? @map("phone") @db.VarChar(20)
  city      String? @map("city") @db.VarChar(100)
  district  String? @map("district") @db.VarChar(100)
  avatarUrl String? @map("avatar_url") @db.VarChar(500)
  avatarKey String? @map("avatar_key") @db.VarChar(500) // MinIO object key

  // Gamification & Security
  points        Int      @default(0)
  trustScore    Int      @default(50) @map("trust_score")
  recoveryCodes String[] @map("recovery_codes") // 2FA Kurtarma kodları


  // Refresh tokens ve şifre sıfırlama
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  // İlişkiler
  issues        Issue[]
  upvotes       IssueUpvote[]
  comments      IssueComment[]
  auditLogs     AuditLog[]
  statusChanges IssueStatusHistory[] @relation("StatusChanges")
  notifications Notification[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@index([institutionId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  token     String   @unique @db.VarChar(512)
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Institution {
  id           String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String  @db.VarChar(255)
  city         String  @db.VarChar(100)
  district     String  @db.VarChar(100)
  webhookUrl   String? @map("webhook_url") @db.VarChar(500)
  emailAddress String  @map("email_address") @db.VarChar(255)
  isActive     Boolean @default(true) @map("is_active")

  // PostGIS MULTIPOLYGON — kurumun sorumlu bölge sınırı
  // Prisma PostGIS Unsupported tipi için raw SQL ile yönetilir
  boundary Unsupported("geometry(MULTIPOLYGON, 4326)")?

  users User[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([city, district])
  @@map("institutions")
}

model Issue {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title       String      @db.VarChar(200)
  description String      @db.Text
  category    Category
  priority    Priority    @default(MEDIUM)
  status      IssueStatus @default(OPEN)

  // ─── Konum ───────────────────────────────────────────────────────────────
  // PostGIS Point — geometrik indexleme için
  location  Unsupported("geometry(POINT, 4326)")
  latitude  Float
  longitude Float
  city      String                               @db.VarChar(100)
  district  String                               @db.VarChar(100)
  address   String?                              @db.VarChar(500)

  // ─── Medya ───────────────────────────────────────────────────────────────
  imageUrl       String? @map("image_url") @db.VarChar(500)
  imageKey       String? @map("image_key") @db.VarChar(500) // MinIO object key
  imageBlurred   Boolean @default(false) @map("image_blurred")
  imageProcessed Boolean @default(false) @map("image_processed")

  // ─── Güvenlik & Doğrulama ────────────────────────────────────────────────
  exifLatitude  Float?  @map("exif_latitude")
  exifLongitude Float?  @map("exif_longitude")
  exifVerified  Boolean @default(false) @map("exif_verified")
  exifDistance  Float?  @map("exif_distance") // metre cinsinden sapma

  // LLM Guard sonucu
  llmGuardPassed Boolean @default(false) @map("llm_guard_passed")
  llmGuardReason String? @map("llm_guard_reason") @db.VarChar(500)

  // SLA Takibi
  slaBreached Boolean @default(false) @map("sla_breached")

  // Güvenlik
  ipAddress String  @map("ip_address") @db.VarChar(45) // IPv6 için 45
  userAgent String? @map("user_agent") @db.VarChar(500)

  // ─── İlişkiler ───────────────────────────────────────────────────────────
  reportedById String @map("reported_by_id") @db.Uuid
  reportedBy   User   @relation(fields: [reportedById], references: [id], onDelete: Cascade)

  upvoteCount Int @default(0) @map("upvote_count")

  statusHistory IssueStatusHistory[]
  upvotes       IssueUpvote[]
  comments      IssueComment[]

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  resolvedAt DateTime? @map("resolved_at")

  @@index([status])
  @@index([category])
  @@index([city, district])
  @@index([createdAt(sort: Desc)])
  @@index([reportedById])
  // PostGIS GiST index — raw SQL migration ile eklenir
  @@map("issues")
}

model IssueStatusHistory {
  id         String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  issueId    String      @map("issue_id") @db.Uuid
  issue      Issue       @relation(fields: [issueId], references: [id], onDelete: Cascade)
  fromStatus IssueStatus @map("from_status")
  toStatus   IssueStatus @map("to_status")
  changedBy  String?     @map("changed_by") @db.Uuid
  changedByUser User?    @relation("StatusChanges", fields: [changedBy], references: [id], onDelete: SetNull)
  note       String?     @db.Text
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([issueId])
  @@map("issue_status_history")
}

model IssueUpvote {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  issueId   String   @map("issue_id") @db.Uuid
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([issueId, userId]) // Bir kullanıcı bir sorunu sadece bir kez oylayabilir
  @@map("issue_upvotes")
}

model IssueComment {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  issueId    String   @map("issue_id") @db.Uuid
  issue      Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  authorId   String   @map("author_id") @db.Uuid
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  isOfficial Boolean  @default(false) @map("is_official")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([issueId])
  @@index([authorId])
  @@map("issue_comments")
}

model AuditLog {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String   @db.VarChar(100)
  targetId   String?  @map("target_id") @db.Uuid
  targetType String?  @map("target_type") @db.VarChar(50)
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([action])
  @@index([targetId])
  @@map("audit_logs")
}

model AiModerationLog {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  issueId   String?  @map("issue_id") @db.Uuid // bağlı issue (oluşturulduysa)
  layer     String   @db.VarChar(50) // "local", "openai_moderation", "llm_guardrail", "vision"
  passed    Boolean
  code      String   @db.VarChar(100)
  reason    String?  @db.Text
  latencyMs Int      @map("latency_ms")
  model     String   @db.VarChar(50) // "gpt-4o-mini", "google-vision" vb.
  createdAt DateTime @default(now()) @map("created_at")

  @@index([issueId])
  @@index([layer])
  @@index([createdAt])
  @@map("ai_moderation_logs")
}

model SystemPrompt {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  key       String   @db.VarChar(100) // e.g., "GUARDRAIL", "VISION", "CHATBOT"
  version   Int      @default(1)
  content   String   @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([key, version]) // Her key'in aynı versiyonundan sadece 1 tane olabilir
  @@index([key, isActive])
  @@map("system_prompts")
}

model PasswordResetToken {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  token     String   @unique @db.VarChar(64)
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model Notification {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @db.VarChar(200)
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  type      String   @db.VarChar(50) // e.g., 'STATUS_UPDATE', 'SYSTEM', 'SLA_ALERT'
  link      String?  @db.VarChar(500) // Tıklandığında gidilecek URL
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@map("notifications")
}

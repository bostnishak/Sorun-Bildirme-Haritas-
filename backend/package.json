{
  "name": "etiya-project-backend",
  "version": "1.0.0",
  "description": "Etiya Project - Türkiye Sorun Bildirim Haritası Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/jobs/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:worker": "node dist/jobs/worker.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test": "jest --forceExit",
    "test:e2e": "jest --config jest.e2e.config.ts --forceExit",
    "test:coverage": "jest --coverage --forceExit"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.1.1",
    "@google-cloud/vision": "^4.0.2",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.42.0",
    "@prisma/client": "^5.14.0",
    "@sentry/node": "^10.63.0",
    "@sentry/profiling-node": "^10.63.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.8.4",
    "cors": "^2.8.5",
    "cron": "^3.1.7",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "exif-parser": "^0.1.12",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "openai": "^4.52.0",
    "opossum": "^10.0.0",
    "p-retry": "^4.6.2",
    "prom-client": "^15.1.3",
    "puppeteer": "^22.12.0",
    "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^5.0.3",
    "sharp": "^0.33.4",
    "soap": "^1.0.0",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.13.0",
    "winston-loki": "^6.1.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.10",
    "@types/nodemailer": "^6.4.24",
    "@types/opossum": "^8.1.9",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^9.7.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "prisma": "^5.14.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "prisma": {
    "seed": "ts-node -T prisma/seed.ts"
  }
}

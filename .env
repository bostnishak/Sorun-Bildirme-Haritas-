# ─── DATABASE ───────────────────────────────────────────────────────────────
DB_USER=chaosmap_user
DB_PASSWORD=change_this_strong_password
DATABASE_URL=postgresql://chaosmap_user:change_this_strong_password@localhost:5432/chaosmap

# ─── REDIS ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_this_redis_password
REDIS_URL=redis://:change_this_redis_password@localhost:6379

# ─── MINIO (S3-Compatible Object Storage) ───────────────────────────────────
MINIO_USER=minioadmin
MINIO_PASSWORD=change_this_minio_password
MINIO_BUCKET=chaosmap-media

# ─── JWT ────────────────────────────────────────────────────────────────────
# MUST be at least 32 characters random string
JWT_SECRET=change_this_to_a_very_long_random_string_minimum_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── AI SERVICES ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
# Google Cloud Vision service account JSON (stringified)
GOOGLE_VISION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ─── MAP ────────────────────────────────────────────────────────────────────
MAPBOX_TOKEN=pk.eyJ1...

# ─── NVİ (T.C. Kimlik Doğrulama) ────────────────────────────────────────────
NVI_ENDPOINT=https://tckimlik.nvi.gov.tr/Service/KPSPublic.asmx

# ─── EMAIL ──────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@chaosmap.tr
SMTP_PASS=your_app_password_here
EMAIL_FROM="ChaosMind <noreply@chaosmap.tr>"

# ─── WEBHOOKS ───────────────────────────────────────────────────────────────
WEBHOOK_HMAC_SECRET=change_this_webhook_hmac_secret

# ─── APP ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost,http://localhost:3000
APP_URL=http://localhost

# ─── GÜVENLİK ───────────────────────────────────────────────────────────────
# TC Kimlik hash pepper — JWT_SECRET'tan BAĞIMSIZ olmalı; ASLA değiştirme!
# Değiştirilirse tüm kayıtlı kullanıcıların kimlik doğrulaması bozulur.
TC_KIMLIK_PEPPER=change_this_to_a_unique_pepper_min_16_chars
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_this_minio_password